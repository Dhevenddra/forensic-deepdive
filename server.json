{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Dhevenddra/forensic-deepdive",
  "description": "Persistent code knowledge graph + 9 composite MCP tools for AI coding agents.",
  "version": "0.9.0",
  "repository": {
    "url": "https://github.com/Dhevenddra/forensic-deepdive",
    "source": "github"
  },
  "websiteUrl": "https://github.com/Dhevenddra/forensic-deepdive",
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "forensic-deepdive",
      "version": "0.9.0",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "serve",
          "valueHint": "command"
        },
        {
          "type": "named",
          "name": "--repo",
          "value": ".",
          "valueHint": "repo_path"
        }
      ]
    }
  ]
}
